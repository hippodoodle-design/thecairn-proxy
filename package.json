{
  "name": "thecairn-proxy",
  "private": true,
  "version": "0.1.0",
  "description": "Cairn backend: Express API (thecairn-web) + BullMQ worker (thecairn-worker) + Redis queue.",
  "workspaces": [
    "shared",
    "web",
    "worker"
  ],
  "scripts": {
    "dev:redis": "docker compose up redis",
    "dev:web": "cd web && node --watch src/server.js",
    "dev:worker": "cd worker && node --watch src/worker.js"
  },
  "engines": {
    "node": ">=20"
  }
}
