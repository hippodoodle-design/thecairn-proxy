# ---- Supabase ----
# Project URL, e.g. https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# Service-role key (worker uses this to insert into stones bypassing RLS).
# NEVER expose this to a browser.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret from Supabase -> Settings -> API -> JWT Settings.
# Web uses this to verify user access tokens from the frontend.
SUPABASE_JWT_SECRET=

# ---- Redis / BullMQ ----
# Railway provides this in prod. Local dev: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ---- Web service ----
PORT=3001
NODE_ENV=development

# Comma-separated allowlist. Defaults to:
# https://www.thecairn.app,https://thecairn.app,http://localhost:5173
ALLOWED_ORIGINS=https://www.thecairn.app,https://thecairn.app,http://localhost:5173
